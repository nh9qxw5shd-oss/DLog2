# Supabase — incident storage & historical trend charts
# Copy this file to .env.local and fill in your project values.
# Both values are safe to expose client-side (anon key is public by design).
# Secure access with Row Level Security policies in your Supabase project.

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
